# EPIC genetics root environment
# Stage-specific .env files are not supported.

GENETICS_PROJECT_ROOT="${GENETICS_PROJECT_ROOT:-/CHANGE/CHANGE/CHANGE/Genetics/work}"
GENETICS_DATA_SOURCE_ROOT="${GENETICS_DATA_SOURCE_ROOT:-/CHANGE/CHANGE/CHANGE/Genetics/sources/Gwas}"
APPTAINER_BINDPATH="${APPTAINER_BINDPATH:-/CHANGE:/CHANGE}"
SCRATCH="${SCRATCH:-/scratch/${USER}/epic-genetics}"
# Date label for this analysis run. All pipeline stages write under ${SCRATCH}/${SCRATCH_DATE}/
# so all stages share the same directory tree. Update this when starting a new analysis run.
SCRATCH_DATE="2026-05-31"
SCRATCH_RUN="${SCRATCH_RUN:-${SCRATCH}/${SCRATCH_DATE}}"

DATA_ROOT="${DATA_ROOT:-${GENETICS_PROJECT_ROOT}/CHANGE}"
ANALYSIS_ROOT="${ANALYSIS_ROOT:-${SCRATCH_RUN}/studies}"
REPORT_DIR="${REPORT_DIR:-${SCRATCH_RUN}/report}"
TOOLS_DIR="${TOOLS_DIR:-${GENETICS_PROJECT_ROOT}/tools}"
REF_DIR="${REF_DIR:-${DATA_ROOT}/reference}"
GENETICS_TOOLS_BIN="${GENETICS_TOOLS_BIN:-${TOOLS_DIR}/bin}"
GENETICS_TOOLS_LIB="${GENETICS_TOOLS_LIB:-${TOOLS_DIR}/lib}"

PYTHON3_BIN="${PYTHON3_BIN:-python3}"
RSCRIPT_BIN="${RSCRIPT_BIN:-Rscript}"
PYTHON2_BIN="${PYTHON2_BIN:-${GENETICS_PROJECT_ROOT}/.conda/py27/bin/python2.7}"
PLINK_BIN="${PLINK_BIN:-plink}"
PLINK2_BIN="${PLINK2_BIN:-plink2}"
BCFTOOLS_BIN="${BCFTOOLS_BIN:-bcftools}"
SHAPEIT5_BIN="${SHAPEIT5_BIN:-shapeit5}"
SHAPEIT5_COMMON_BIN="${SHAPEIT5_COMMON_BIN:-SHAPEIT5_phase_common}"
MINIMAC4_BIN="${MINIMAC4_BIN:-minimac4}"
PICARD_BIN="${PICARD_BIN:-picard}"

CONFORM_GT_JAR="${CONFORM_GT_JAR:-${TOOLS_DIR}/conform-gt.24May16.cee.jar}"
ANNOVAR_DIR="${ANNOVAR_DIR:-${TOOLS_DIR}/annovar}"
TRIPLE_LIFTOVER_DIR="${TRIPLE_LIFTOVER_DIR:-${TOOLS_DIR}/triple-liftOver}"
STAGE1_TRIPLE_LIFTOVER_DIR="${STAGE1_TRIPLE_LIFTOVER_DIR:-${TRIPLE_LIFTOVER_DIR}}"

# Stage 1.
STAGE1_DATA_ROOT="${STAGE1_DATA_ROOT:-${DATA_ROOT}}"
STAGE1_OUTDIR="${STAGE1_OUTDIR:-${ANALYSIS_ROOT}}"
STAGE1_WORK_ROOT="${STAGE1_WORK_ROOT:-${SCRATCH_RUN}/stage1/work}"
STAGE1_NEXTFLOW_WORKDIR="${STAGE1_NEXTFLOW_WORKDIR:-${SCRATCH_RUN}/stage1/nxf-work}"
STAGE1_JOB_NAME="${STAGE1_JOB_NAME:-stage1_process}"
STAGE1_TIME="${STAGE1_TIME:-10-00:00:00}"
STAGE1_MEM="${STAGE1_MEM:-32G}"
STAGE1_CPUS="${STAGE1_CPUS:-2}"
STAGE1_PARTITION="low_p"
EPIC_CASE_STATUS_FILE="${EPIC_CASE_STATUS_FILE:-${STAGE1_DATA_ROOT}/reference/Epic/EPIC_study_case_status.txt}"
CHECK_REFBUILD_SH="${CHECK_REFBUILD_SH:-${GENETICS_PROJECT_ROOT}/pipeline_stage1/bin/check_RefBuild.sh}"

# Stage 2.
IMPUTATION_OUTDIR="${IMPUTATION_OUTDIR:-${ANALYSIS_ROOT}}"
IMPUTATION_STAGE1_ROOT="${IMPUTATION_STAGE1_ROOT:-${ANALYSIS_ROOT}}"
IMPUTATION_REF_1000G_DIR="${IMPUTATION_REF_1000G_DIR:-${REF_DIR}/1000G}"
IMPUTATION_FASTA_REF="${IMPUTATION_FASTA_REF:-${IMPUTATION_REF_1000G_DIR}/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna}"
STAGE2_SHAPEIT5_MAP_DIR="${STAGE2_SHAPEIT5_MAP_DIR:-${REF_DIR}/shapeit5/maps}"
IMPUTATION_WORKDIR="${IMPUTATION_WORKDIR:-${SCRATCH_RUN}/stage2/work}"
IMPUTATION_CONDA_CACHE_DIR="${IMPUTATION_CONDA_CACHE_DIR:-${SCRATCH_RUN}/stage2/conda}"
IMPUTATION_PROFILE="${IMPUTATION_PROFILE:-slurm}"
IMPUTATION_PARTITION="low_p"
IMPUTATION_EXECUTOR_QUEUE_SIZE="${IMPUTATION_EXECUTOR_QUEUE_SIZE:-1000}"
IMPUTATION_RUN_EMPIRICAL_VALIDATION="${IMPUTATION_RUN_EMPIRICAL_VALIDATION:-true}"

# Stage 3.
STAGE3_OUTDIR="${STAGE3_OUTDIR:-${ANALYSIS_ROOT}}"
STAGE3_STAGE1_ROOT="${STAGE3_STAGE1_ROOT:-${ANALYSIS_ROOT}}"
STAGE3_STAGE2_ROOT="${STAGE3_STAGE2_ROOT:-${ANALYSIS_ROOT}}"
STAGE3_WORKDIR="${STAGE3_WORKDIR:-${SCRATCH_RUN}/stage3/work}"
STAGE3_CONDA_CACHE_DIR="${STAGE3_CONDA_CACHE_DIR:-${SCRATCH_RUN}/stage3/conda}"
STAGE3_PROFILE="${STAGE3_PROFILE:-slurm}"
STAGE3_PARTITION="low_p"
STAGE3_CACHE_MODE="${STAGE3_CACHE_MODE:-lenient}"
STAGE3_QUEUE_SIZE="${STAGE3_QUEUE_SIZE:-2000}"
STAGE3_SUBMIT_RATE_LIMIT="${STAGE3_SUBMIT_RATE_LIMIT:-2000/1min}"
STAGE3_MIN_R2="${STAGE3_MIN_R2:-0.3}"
STAGE3_MAF="${STAGE3_MAF:-0.01}"
STAGE3_RUN_HWE="${STAGE3_RUN_HWE:-true}"
STAGE3_EXCLUDE_ANCESTRY_OUTLIERS="${STAGE3_EXCLUDE_ANCESTRY_OUTLIERS:-true}"
STAGE3_PREP_DBSNP_CPUS="${STAGE3_PREP_DBSNP_CPUS:-1}"
STAGE3_PREP_DBSNP_MEMORY="${STAGE3_PREP_DBSNP_MEMORY:-4 GB}"
STAGE3_PREP_DBSNP_TIME="${STAGE3_PREP_DBSNP_TIME:-72h}"
STAGE3_FILTER_CHROM_CPUS="${STAGE3_FILTER_CHROM_CPUS:-1}"
STAGE3_FILTER_CHROM_MEMORY="${STAGE3_FILTER_CHROM_MEMORY:-8 GB}"
STAGE3_FILTER_CHROM_TIME="${STAGE3_FILTER_CHROM_TIME:-72h}"
STAGE3_ANNOTATE_CHROM_CPUS="${STAGE3_ANNOTATE_CHROM_CPUS:-1}"
STAGE3_ANNOTATE_CHROM_MEMORY="${STAGE3_ANNOTATE_CHROM_MEMORY:-8 GB}"
STAGE3_ANNOTATE_CHROM_TIME="${STAGE3_ANNOTATE_CHROM_TIME:-72h}"
STAGE3_IMPORT_CHROM_CPUS="${STAGE3_IMPORT_CHROM_CPUS:-4}"
STAGE3_IMPORT_CHROM_MEMORY="${STAGE3_IMPORT_CHROM_MEMORY:-16 GB}"
STAGE3_IMPORT_CHROM_TIME="${STAGE3_IMPORT_CHROM_TIME:-72h}"
STAGE3_HWE_CHROM_CPUS="${STAGE3_HWE_CHROM_CPUS:-1}"
STAGE3_HWE_CHROM_MEMORY="${STAGE3_HWE_CHROM_MEMORY:-8 GB}"
STAGE3_HWE_CHROM_TIME="${STAGE3_HWE_CHROM_TIME:-72h}"
STAGE3_MERGE_STUDY_CPUS="${STAGE3_MERGE_STUDY_CPUS:-4}"
STAGE3_MERGE_STUDY_MEMORY="${STAGE3_MERGE_STUDY_MEMORY:-32 GB}"
STAGE3_MERGE_STUDY_TIME="${STAGE3_MERGE_STUDY_TIME:-72h}"
STAGE3_PRUNE_AUTOSOMES_CPUS="${STAGE3_PRUNE_AUTOSOMES_CPUS:-4}"
STAGE3_PRUNE_AUTOSOMES_MEMORY="${STAGE3_PRUNE_AUTOSOMES_MEMORY:-32 GB}"
STAGE3_PRUNE_AUTOSOMES_TIME="${STAGE3_PRUNE_AUTOSOMES_TIME:-72h}"
STAGE3_KING_QC_CPUS="${STAGE3_KING_QC_CPUS:-4}"
STAGE3_KING_QC_MEMORY="${STAGE3_KING_QC_MEMORY:-32 GB}"
STAGE3_KING_QC_TIME="${STAGE3_KING_QC_TIME:-72h}"
STAGE3_HET_PCA_QC_CPUS="${STAGE3_HET_PCA_QC_CPUS:-4}"
STAGE3_HET_PCA_QC_MEMORY="${STAGE3_HET_PCA_QC_MEMORY:-32 GB}"
STAGE3_HET_PCA_QC_TIME="${STAGE3_HET_PCA_QC_TIME:-72h}"
STAGE3_SAMPLE_REVIEW_SUMMARY_CPUS="${STAGE3_SAMPLE_REVIEW_SUMMARY_CPUS:-4}"
STAGE3_SAMPLE_REVIEW_SUMMARY_MEMORY="${STAGE3_SAMPLE_REVIEW_SUMMARY_MEMORY:-32 GB}"
STAGE3_SAMPLE_REVIEW_SUMMARY_TIME="${STAGE3_SAMPLE_REVIEW_SUMMARY_TIME:-72h}"
STAGE3_FINALIZE_CHROM_CPUS="${STAGE3_FINALIZE_CHROM_CPUS:-1}"
STAGE3_FINALIZE_CHROM_MEMORY="${STAGE3_FINALIZE_CHROM_MEMORY:-16 GB}"
STAGE3_FINALIZE_CHROM_TIME="${STAGE3_FINALIZE_CHROM_TIME:-72h}"
STAGE3_PUBLISH_INTERMEDIATE_PLINK="${STAGE3_PUBLISH_INTERMEDIATE_PLINK:-false}"


# Stage 4 (007_stage4.sh) — master report + finalisation.
STAGE4_ANALYSIS_ROOT="${STAGE4_ANALYSIS_ROOT:-${SCRATCH_RUN}/studies}"
STAGE4_STAGE2_ROOT="${STAGE4_STAGE2_ROOT:-${SCRATCH_RUN}/studies}"
STAGE4_STAGE3_ROOT="${STAGE4_STAGE3_ROOT:-${SCRATCH_RUN}/studies}"
STAGE4_DEST_ROOT="${STAGE4_DEST_ROOT:-${SCRATCH_RUN}/final}"
STAGE4_REPORT_DIR="${STAGE4_REPORT_DIR:-${STAGE4_DEST_ROOT}/report}"
STAGE4_JOB_NAME="${STAGE4_JOB_NAME:-stage4_finalise}"
STAGE4_TIME="${STAGE4_TIME:-24:00:00}"
STAGE4_MEM="${STAGE4_MEM:-16G}"
STAGE4_CPUS="${STAGE4_CPUS:-2}"
STAGE4_PARTITION="low_p"
STAGE4_MASTER_REPORT_CPUS="${STAGE4_MASTER_REPORT_CPUS:-1}"
STAGE4_MASTER_REPORT_MEMORY="${STAGE4_MASTER_REPORT_MEMORY:-8 GB}"
STAGE4_MASTER_REPORT_TIME="${STAGE4_MASTER_REPORT_TIME:-4h}"
STAGE4_FINALISE_STUDY_CPUS="${STAGE4_FINALISE_STUDY_CPUS:-8}"
STAGE4_FINALISE_STUDY_MEMORY="${STAGE4_FINALISE_STUDY_MEMORY:-16 GB}"
STAGE4_FINALISE_STUDY_TIME="${STAGE4_FINALISE_STUDY_TIME:-24h}"
