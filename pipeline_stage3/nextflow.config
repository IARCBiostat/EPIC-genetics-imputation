manifest {
    name = 'EPIC-genetics-stage3'
    description = 'EPIC Genetics Stage-3 post-imputation QC and PLINK2 conversion'
    version = '1.0.0'
}

workDir = "${projectDir}/work"

conda {
    enabled = true
    useMamba = false
    cacheDir = "${projectDir}/conda"
}

params {
    outdir = "${projectDir}/../analysis"
    stage1_root = "${projectDir}/../analysis"
    stage2_root = "${projectDir}/../analysis"
    slurm_partition = System.getenv('STAGE3_PARTITION') ?: (System.getenv('SLURM_JOB_PARTITION') ?: 'low_p')
    cache_mode = System.getenv('STAGE3_CACHE_MODE') ?: 'lenient'
    stage3_queue_size = (System.getenv('STAGE3_QUEUE_SIZE') ?: '2000').toInteger()
    stage3_submit_rate_limit = System.getenv('STAGE3_SUBMIT_RATE_LIMIT') ?: '2000/1min'

    prep_dbsnp_cpus = (System.getenv('STAGE3_PREP_DBSNP_CPUS') ?: '1').toInteger()
    prep_dbsnp_memory = System.getenv('STAGE3_PREP_DBSNP_MEMORY') ?: '4 GB'
    prep_dbsnp_time = System.getenv('STAGE3_PREP_DBSNP_TIME') ?: '1h'

    prep_chrom_cpus = (System.getenv('STAGE3_PREP_CHROM_CPUS') ?: '1').toInteger()
    prep_chrom_memory = System.getenv('STAGE3_PREP_CHROM_MEMORY') ?: '8 GB'
    prep_chrom_time = System.getenv('STAGE3_PREP_CHROM_TIME') ?: '12h'

    sample_review_cpus = (System.getenv('STAGE3_SAMPLE_REVIEW_CPUS') ?: '4').toInteger()
    sample_review_memory = System.getenv('STAGE3_SAMPLE_REVIEW_MEMORY') ?: '32 GB'
    sample_review_time = System.getenv('STAGE3_SAMPLE_REVIEW_TIME') ?: '24h'

    finalize_study_cpus = (System.getenv('STAGE3_FINALIZE_STUDY_CPUS') ?: '1').toInteger()
    finalize_study_memory = System.getenv('STAGE3_FINALIZE_STUDY_MEMORY') ?: '16 GB'
    finalize_study_time = System.getenv('STAGE3_FINALIZE_STUDY_TIME') ?: '4h'
}

singularity.enabled = false

env {
    BCFTOOLS_BIN = System.getenv('BCFTOOLS_BIN') ?: 'bcftools'
    PLINK_BIN = System.getenv('PLINK_BIN') ?: 'plink'
    PLINK2_BIN = System.getenv('PLINK2_BIN') ?: 'plink2'
    PYTHON3_BIN = System.getenv('PYTHON3_BIN') ?: 'python3'
}

process {
    executor = 'local'
    cache = params.cache_mode
    errorStrategy = 'finish'

    withName: PREP_DBSNP_CHROM {
        cpus = params.prep_dbsnp_cpus
        memory = params.prep_dbsnp_memory
        time = params.prep_dbsnp_time
        conda = "${projectDir}/envs/prepare_dbsnp.yml"
    }

    withName: PREP_CHROM {
        cpus = params.prep_chrom_cpus
        memory = params.prep_chrom_memory
        time = params.prep_chrom_time
        conda = "${projectDir}/envs/prepare_chrom.yml"
    }

    withName: SAMPLE_REVIEW {
        cpus = params.sample_review_cpus
        memory = params.sample_review_memory
        time = params.sample_review_time
        conda = "${projectDir}/envs/sample_review.yml"
    }

    withName: FINALIZE_STUDY {
        cpus = params.finalize_study_cpus
        memory = params.finalize_study_memory
        time = params.finalize_study_time
        conda = "${projectDir}/envs/finalize_study.yml"
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = params.slurm_partition
        process.errorStrategy = 'terminate'
        process.maxRetries = 0
        executor.queueSize = params.stage3_queue_size
        executor.submitRateLimit = params.stage3_submit_rate_limit
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/stage3-pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/stage3-pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/stage3-pipeline_info/execution_trace.txt"
    overwrite = true
}
