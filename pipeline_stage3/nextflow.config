manifest {
    name = 'EPIC-genetics-stage3'
    description = 'EPIC Genetics Stage-3 post-imputation QC and PLINK2 conversion'
    version = '1.0.0'
}

conda {
    enabled = true
    useMamba = false
    cacheDir = System.getenv('NXF_CONDA_CACHEDIR') ?: "${projectDir}/conda"
}

cleanup = true

params {
    outdir = "${projectDir}/../analysis"
    stage1_root = "${projectDir}/../analysis"
    stage2_root = "${projectDir}/../analysis"
    pipeline_info_dir = "${params.outdir}/stage3-pipeline_info"
    slurm_partition = System.getenv('STAGE3_PARTITION') ?: 'low_p'
    cache_mode = System.getenv('STAGE3_CACHE_MODE') ?: 'lenient'
    stage3_queue_size = (System.getenv('STAGE3_QUEUE_SIZE') ?: '2000').toInteger()
    stage3_submit_rate_limit = System.getenv('STAGE3_SUBMIT_RATE_LIMIT') ?: '2000/1min'
    publish_intermediate_plink = (System.getenv('STAGE3_PUBLISH_INTERMEDIATE_PLINK') ?: 'false').toBoolean()

    prep_dbsnp_cpus = (System.getenv('STAGE3_PREP_DBSNP_CPUS') ?: '1').toInteger()
    prep_dbsnp_memory = System.getenv('STAGE3_PREP_DBSNP_MEMORY') ?: '4 GB'
    prep_dbsnp_time = System.getenv('STAGE3_PREP_DBSNP_TIME') ?: '72h'

    prepare_chrom_cpus = (System.getenv('STAGE3_PREPARE_CHROM_CPUS') ?: '4').toInteger()
    prepare_chrom_memory = System.getenv('STAGE3_PREPARE_CHROM_MEMORY') ?: '8 GB'
    prepare_chrom_time = System.getenv('STAGE3_PREPARE_CHROM_TIME') ?: '72h'

    import_chrom_cpus = (System.getenv('STAGE3_IMPORT_CHROM_CPUS') ?: '8').toInteger()
    import_chrom_memory = System.getenv('STAGE3_IMPORT_CHROM_MEMORY') ?: '32 GB'
    import_chrom_time = System.getenv('STAGE3_IMPORT_CHROM_TIME') ?: '72h'

    hwe_chrom_cpus = (System.getenv('STAGE3_HWE_CHROM_CPUS') ?: '1').toInteger()
    hwe_chrom_memory = System.getenv('STAGE3_HWE_CHROM_MEMORY') ?: '8 GB'
    hwe_chrom_time = System.getenv('STAGE3_HWE_CHROM_TIME') ?: '72h'

    prune_chrom_cpus = (System.getenv('STAGE3_PRUNE_CHROM_CPUS') ?: '2').toInteger()
    prune_chrom_memory = System.getenv('STAGE3_PRUNE_CHROM_MEMORY') ?: '8 GB'
    prune_chrom_time = System.getenv('STAGE3_PRUNE_CHROM_TIME') ?: '72h'

    merge_pruned_cpus = (System.getenv('STAGE3_MERGE_PRUNED_CPUS') ?: '4').toInteger()
    merge_pruned_memory = System.getenv('STAGE3_MERGE_PRUNED_MEMORY') ?: '32 GB'
    merge_pruned_time = System.getenv('STAGE3_MERGE_PRUNED_TIME') ?: '72h'

    make_update_files_cpus = (System.getenv('STAGE3_MAKE_UPDATE_FILES_CPUS') ?: '1').toInteger()
    make_update_files_memory = System.getenv('STAGE3_MAKE_UPDATE_FILES_MEMORY') ?: '4 GB'
    make_update_files_time = System.getenv('STAGE3_MAKE_UPDATE_FILES_TIME') ?: '1h'

    king_qc_cpus = (System.getenv('STAGE3_KING_QC_CPUS') ?: '4').toInteger()
    king_qc_memory = System.getenv('STAGE3_KING_QC_MEMORY') ?: '32 GB'
    king_qc_time = System.getenv('STAGE3_KING_QC_TIME') ?: '72h'

    het_pca_qc_cpus = (System.getenv('STAGE3_HET_PCA_QC_CPUS') ?: '4').toInteger()
    het_pca_qc_memory = System.getenv('STAGE3_HET_PCA_QC_MEMORY') ?: '32 GB'
    het_pca_qc_time = System.getenv('STAGE3_HET_PCA_QC_TIME') ?: '72h'

    sample_review_summary_cpus = (System.getenv('STAGE3_SAMPLE_REVIEW_SUMMARY_CPUS') ?: '4').toInteger()
    sample_review_summary_memory = System.getenv('STAGE3_SAMPLE_REVIEW_SUMMARY_MEMORY') ?: '32 GB'
    sample_review_summary_time = System.getenv('STAGE3_SAMPLE_REVIEW_SUMMARY_TIME') ?: '72h'

    finalize_chrom_cpus = (System.getenv('STAGE3_FINALIZE_CHROM_CPUS') ?: '1').toInteger()
    finalize_chrom_memory = System.getenv('STAGE3_FINALIZE_CHROM_MEMORY') ?: '16 GB'
    finalize_chrom_time = System.getenv('STAGE3_FINALIZE_CHROM_TIME') ?: '72h'

}

singularity.enabled = false

env {
    BCFTOOLS_BIN = System.getenv('BCFTOOLS_BIN') ?: 'bcftools'
    PLINK_BIN = System.getenv('PLINK_BIN') ?: 'plink'
    PLINK2_BIN = System.getenv('PLINK2_BIN') ?: 'plink2'
    PYTHON3_BIN = System.getenv('PYTHON3_BIN') ?: 'python3'
}

process {
    executor = 'local'
    cache = params.cache_mode
    errorStrategy = 'retry'
    maxRetries = 3
    stageInMode = 'symlink'

    withName: PREP_DBSNP_CHROM {
        cpus = params.prep_dbsnp_cpus
        memory = params.prep_dbsnp_memory
        time = params.prep_dbsnp_time
        conda = "${projectDir}/envs/prepare_dbsnp.yml"
        cache = 'lenient'
    }

    withName: PREPARE_CHROM {
        cpus = params.prepare_chrom_cpus
        memory = params.prepare_chrom_memory
        time = params.prepare_chrom_time
        conda = "${projectDir}/envs/prepare_chrom.yml"
        cache = 'lenient'
    }

    withName: IMPORT_CHROM {
        cpus = params.import_chrom_cpus
        memory = params.import_chrom_memory
        time = params.import_chrom_time
        conda = "${projectDir}/envs/prepare_chrom.yml"
        cache = 'lenient'
    }

    withName: HWE_CHROM {
        cpus = params.hwe_chrom_cpus
        memory = params.hwe_chrom_memory
        time = params.hwe_chrom_time
        conda = "${projectDir}/envs/prepare_chrom.yml"
        cache = 'lenient'
        afterScript = 'sync'
    }

    withName: PRUNE_CHROM_FOR_QC {
        cpus = params.prune_chrom_cpus
        memory = params.prune_chrom_memory
        time = params.prune_chrom_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: MERGE_PRUNED_FOR_QC {
        cpus = params.merge_pruned_cpus
        memory = params.merge_pruned_memory
        time = params.merge_pruned_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: MAKE_UPDATE_FILES {
        cpus = params.make_update_files_cpus
        memory = params.make_update_files_memory
        time = params.make_update_files_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: KING_QC {
        cpus = params.king_qc_cpus
        memory = params.king_qc_memory
        time = params.king_qc_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: HET_PCA_QC {
        cpus = params.het_pca_qc_cpus
        memory = params.het_pca_qc_memory
        time = params.het_pca_qc_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: SAMPLE_REVIEW_SUMMARY {
        cpus = params.sample_review_summary_cpus
        memory = params.sample_review_summary_memory
        time = params.sample_review_summary_time
        conda = "${projectDir}/envs/sample_review.yml"
        cache = 'lenient'
    }

    withName: FINALIZE_CHROM {
        cpus = params.finalize_chrom_cpus
        memory = params.finalize_chrom_memory
        time = params.finalize_chrom_time
        conda = "${projectDir}/envs/finalize_study.yml"
        cache = 'lenient'
    }

}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = System.getenv('STAGE3_PARTITION') ?: 'low_p'
        executor.queueSize = params.stage3_queue_size
        executor.submitRateLimit = params.stage3_submit_rate_limit
    }
}

timeline {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_trace.txt"
    overwrite = true
}
