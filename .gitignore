# Ignore everything
/*
!/.gitignore

# Allow documentation
!/README.md
!/walkthrough.md
!/.env.example

# Allow core logic directories
!/pipeline_stage1/
!/pipeline_stage2/
!/pipeline_stage3/
!/src/

# Exclude specific sub-directories and files within allowed paths
/src/test/
/src/logs/
/pipeline_stage1/.nextflow_work/
/pipeline_stage1/work/
/pipeline_stage2/work/
/pipeline_stage2/conda/
/pipeline_stage2/logs/
/pipeline_stage2/.nextflow/
/pipeline_stage2/.nextflow.log*
/pipeline_stage3/work/
/pipeline_stage3/conda/
/pipeline_stage3/.nextflow/
/pipeline_stage3/.nextflow.log*

# Global ignores (even in allowed paths)
.DS_Store
__pycache__/
*.pyc
*.zip
*.tar.gz
*.log
*.tmp
*.csv
!/pipeline_stage2/*.csv
!/src/*.csv
