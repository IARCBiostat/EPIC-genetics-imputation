manifest {
    name = 'EPIC-genetics-stage4'
    description = 'EPIC Genetics Stage-4 master report generation and study finalisation'
    version = '1.0.0'
}

conda {
    enabled = true
    useMamba = false
    cacheDir = System.getenv('NXF_CONDA_CACHEDIR') ?: "${projectDir}/conda"
    createTimeout = '2 h'
}

params {
    // Resolved from env at launch; 006_stage3.sh passes these explicitly.
    project_root  = System.getenv('GENETICS_PROJECT_ROOT') ?: projectDir.parent.toString()
    analysis_root = System.getenv('STAGE4_ANALYSIS_ROOT')  ?: "${projectDir}/../analysis"
    stage2_root   = System.getenv('STAGE4_STAGE2_ROOT')    ?: params.analysis_root
    stage3_root   = System.getenv('STAGE4_STAGE3_ROOT')    ?: params.analysis_root
    dest_root     = System.getenv('STAGE4_DEST_ROOT')      ?: "${projectDir}/../final"
    report_dir    = System.getenv('STAGE4_REPORT_DIR')     ?: "${params.dest_root}/report"
    pipeline_info_dir = System.getenv('STAGE4_PIPELINE_INFO_DIR') ?: "${projectDir}/../stage4/pipeline_info"

    study = 'all'

    slurm_partition     = System.getenv('STAGE4_PARTITION') ?: 'low_p'
    cache_mode          = System.getenv('STAGE4_CACHE_MODE') ?: 'lenient'
    queue_size          = (System.getenv('STAGE4_QUEUE_SIZE') ?: '100').toInteger()
    submit_rate_limit   = System.getenv('STAGE4_SUBMIT_RATE_LIMIT') ?: '100/1min'

    master_report_cpus   = (System.getenv('STAGE4_MASTER_REPORT_CPUS')   ?: '1').toInteger()
    master_report_memory = System.getenv('STAGE4_MASTER_REPORT_MEMORY')   ?: '8 GB'
    master_report_time   = System.getenv('STAGE4_MASTER_REPORT_TIME')     ?: '4h'

    finalise_study_cpus   = (System.getenv('STAGE4_FINALISE_STUDY_CPUS')   ?: '8').toInteger()
    finalise_study_memory = System.getenv('STAGE4_FINALISE_STUDY_MEMORY')  ?: '16 GB'
    finalise_study_time   = System.getenv('STAGE4_FINALISE_STUDY_TIME')    ?: '4h'
}

singularity.enabled = false

env {
    PYTHON3_BIN = System.getenv('PYTHON3_BIN') ?: 'python3'
}

process {
    executor = 'local'
    cache = params.cache_mode
    errorStrategy = 'finish'
    stageInMode = 'symlink'

    withName: MASTER_REPORT {
        cpus   = params.master_report_cpus
        memory = params.master_report_memory
        time   = params.master_report_time
        conda  = "${projectDir}/envs/report.yml"
        cache  = 'lenient'
    }

    withName: FINALISE_STUDY {
        cpus   = params.finalise_study_cpus
        memory = params.finalise_study_memory
        time   = params.finalise_study_time
        // No conda needed — uses bash/tar/cp from system environment.
        cache  = 'lenient'
        // Copy inputs into work dir so the script reads local files, not NFS symlinks.
        stageInMode = 'copy'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = System.getenv('STAGE4_PARTITION') ?: 'low_p'
        executor.queueSize = params.queue_size
        executor.submitRateLimit = params.submit_rate_limit
    }
}

timeline {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.pipeline_info_dir}/execution_trace.txt"
    overwrite = true
}
