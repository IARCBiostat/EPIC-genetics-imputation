manifest {
    name = 'EPIC-genetics-stage1'
    description = 'EPIC Genetics Stage-1 study processing and report generation'
    version = '1.0.0'
}

workDir = "${projectDir}/.nextflow_work"

params {
    study = 'all'
    data_root = "${projectDir}/../data"
    outdir = "${projectDir}/../analysis"
    work_root = "${projectDir}/work"
    nextflow_work_root = "${projectDir}/.nextflow_work"
    slurm_partition = System.getenv('SLURM_JOB_PARTITION') ?: 'low_p'
    cache_mode = 'deep'
    python3_bin = System.getenv('PYTHON3_BIN') ?: 'python3'
    python2_bin = System.getenv('PYTHON2_BIN') ?: 'python2.7'
    plink_bin = System.getenv('PLINK_BIN') ?: 'plink'
    plink2_bin = System.getenv('PLINK2_BIN') ?: 'plink2'
    sex_check_f_female = 0.2
    sex_check_f_male = 0.8
    sex_check_min_variants = 100
    hwe_p = 0.000001
    het_sd_threshold = 3.0
    king_duplicate_cutoff = 0.354
    maf_phasing = 0.005
}

process {
    executor = 'local'
    cache = params.cache_mode
    errorStrategy = 'finish'
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = params.slurm_partition
        process.cpus = 2
        process.memory = '32 GB'
        process.time = '10d'
        process.errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'terminate' }
        process.maxRetries = 1
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/stage1-pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/stage1-pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file = "${params.outdir}/stage1-pipeline_info/execution_trace.txt"
    overwrite = true
}
