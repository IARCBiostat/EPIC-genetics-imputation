// pipeline_stage2/nextflow.config

manifest {
    name = 'EPIC-genetics'
    description = 'EPIC Genetics Imputation Pipeline using stage-1 hg38 inputs'
    version = '1.0.0'
}

conda {
    enabled = true
    useMamba = false
    cacheDir = System.getenv('NXF_CONDA_CACHEDIR') ?: "${projectDir}/conda"
}

params {
    outdir = "${projectDir}/../analysis"
    logdir = "${projectDir}/../logs"
    pipeline_info_dir = "${params.outdir}/stage2-pipeline_info"
    slurm_partition = System.getenv('SLURM_JOB_PARTITION') ?: 'low_p'
    cache_mode = 'deep'
    executor_queue_size = 1000
    
    // Per-process resources, tuned from the completed stage-2 trace.
    minimac_threads = 4
    phase_cpus = 4
    phase_memory = '6 GB'
    phase_time = '50h'
    phasing_metrics_cpus = 1
    phasing_metrics_memory = '2 GB'
    phasing_metrics_time = '4h'
    impute_cpus = 4
    impute_memory = '8 GB'
    impute_time = '10h'
    chrx_cpus = 4
    chrx_memory = '8 GB'
    chrx_time = '50h'
    metrics_cpus = 1
    metrics_memory = '2 GB'
    metrics_time = '4h'
    reference_cpus = 2
    reference_memory = '4 GB'
    reference_time = '10h'
    target_cpus = 2
    target_memory = '16 GB'
    target_time = '10h'
    shapeit5_map_dir = System.getenv('STAGE2_SHAPEIT5_MAP_DIR') ?: "${projectDir}/../data/reference/shapeit5/maps"
    chrx_force_diploid = true
    chrx_min_ratio = 0.0
    minimac_batch_size = 200
    min_r2 = 0.3
    run_reporting = true
    run_empirical_validation = true
    empirical_min_samples = 20
    dose0_min_samples = 5
    summary_min_r2 = 0.3
    summary_high_quality = 0.8
    empirical_validation_cpus = 1
    empirical_validation_memory = '16 GB'
    empirical_validation_time = '8h'
    reporting_cpus = 4
    reporting_memory = '64 GB'
    reporting_time = '8h'
}

singularity.enabled = false

// Environment variables to support $VAR_BIN syntax in scripts
env {
    PLINK_BIN = System.getenv('PLINK_BIN') ?: 'plink'
    BCFTOOLS_BIN = System.getenv('BCFTOOLS_BIN') ?: 'bcftools'
    SHAPEIT5_COMMON_BIN = System.getenv('SHAPEIT5_COMMON_BIN') ?: 'SHAPEIT5_phase_common'
    MINIMAC4_BIN = System.getenv('MINIMAC4_BIN') ?: 'minimac4'
    PYTHON3_BIN = System.getenv('PYTHON3_BIN') ?: 'python3'
    // Passed to imputation tasks for in-task binary fallback resolution when
    // conda activation is overridden by the PATH above.
    NXF_CONDA_CACHE = System.getenv('NXF_CONDA_CACHEDIR') ?: "${projectDir}/conda"
}

process {
    // Default executor
    executor = 'local'

    // Cache all process results by content so reruns can safely reuse completed
    // tasks via -resume even when files are copied back in or timestamps change.
    cache = params.cache_mode

    // Error handling
    errorStrategy = 'finish'

    withName: PREP_TARGET_VCF {
        conda = "${projectDir}/envs/prep_target_vcf.yml"
        cpus = params.target_cpus
        memory = params.target_memory
        time = params.target_time
        stageInMode = 'link'
    }

    withName: PREP_REFERENCE {
        conda = "${projectDir}/envs/prep_reference.yml"
        cpus = params.reference_cpus
        memory = params.reference_memory
        time = params.reference_time
    }

    withName: PHASE_AUTOSOMES {
        conda = "${projectDir}/envs/phase_autosomes.yml"
        cpus = params.phase_cpus
        memory = params.phase_memory
        time = params.phase_time
    }

    withName: STAGE_PHASING_METRICS {
        conda = "${projectDir}/envs/imputation_metrics.yml"
        cpus = params.phasing_metrics_cpus
        memory = params.phasing_metrics_memory
        time = params.phasing_metrics_time
    }

    withName: IMPUTE_AUTOSOMES {
        conda = "${projectDir}/envs/impute_autosomes.yml"
        cpus = params.impute_cpus
        memory = params.impute_memory
        time = params.impute_time
    }

    withName: IMPUTE_CHRX {
        conda = "${projectDir}/envs/impute_chrx.yml"
        cpus = params.chrx_cpus
        memory = params.chrx_memory
        time = params.chrx_time
    }

    withName: STAGE_IMPUTATION_METRICS {
        conda = "${projectDir}/envs/imputation_metrics.yml"
        cpus = params.metrics_cpus
        memory = params.metrics_memory
        time = params.metrics_time
    }

    withName: STAGE_EMPIRICAL_VALIDATION_METRICS {
        conda = "${projectDir}/envs/imputation_metrics.yml"
        cpus = params.empirical_validation_cpus
        memory = params.empirical_validation_memory
        time = params.empirical_validation_time
    }

    withName: REPORTING {
        conda = "${projectDir}/envs/reports.yml"
        cpus = params.reporting_cpus
        memory = params.reporting_memory
        time = params.reporting_time
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        executor.queueSize = params.executor_queue_size
        process.executor = 'slurm'
        process.queue = params.slurm_partition
        process.cpus = 1
        process.memory = '4GB'
        process.time = '10h'
        // On low_p, tasks can be interrupted by scheduler signals. Retry only
        // those interruption-style exits, while still finishing on real errors.
        process.errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'finish' }
        process.maxRetries = 2

        // REPORTING reads many files over NFS and can hit transient stale-handle
        // errors. Retry up to 2 extra times before giving up.
        process {
            withName: REPORTING {
                errorStrategy = { task.attempt <= 2 ? 'retry' : 'finish' }
                maxRetries = 2
            }
        }
    }
}

timeline {
    enabled = true
    file    = "${params.pipeline_info_dir}/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.pipeline_info_dir}/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.pipeline_info_dir}/execution_trace.txt"
    overwrite = true
}
