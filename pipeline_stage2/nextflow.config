// pipeline_stage2/nextflow.config

manifest {
    name = 'EPIC-genetics'
    description = 'EPIC Genetics Imputation Pipeline using stage-1 hg38 inputs'
    version = '1.0.0'
}

workDir = "${launchDir}/work"

conda {
    enabled = true
    useMamba = false
    cacheDir = "${launchDir}/conda"
}

params {
    outdir = "${launchDir}/../analysis"
    logdir = "${launchDir}/../logs"
    slurm_partition = System.getenv('SLURM_JOB_PARTITION') ?: 'low_p'
    cache_mode = 'deep'
    
    // Default threads and resources
    eagle_threads = 8
    minimac_threads = 8
    minimac_batch_size = 200
    min_r2 = 0.3
}

singularity.enabled = false

// Environment variables to support legacy $VAR_BIN syntax in scripts
env {
    PLINK_BIN = System.getenv('PLINK_BIN') ?: 'plink'
    BCFTOOLS_BIN = System.getenv('BCFTOOLS_BIN') ?: 'bcftools'
    EAGLE_BIN = System.getenv('EAGLE_BIN') ?: 'eagle'
    MINIMAC4_BIN = System.getenv('MINIMAC4_BIN') ?: 'minimac4'
}

process {
    // Default executor
    executor = 'local'

    // Cache all process results by content so reruns can safely reuse completed
    // tasks via -resume even when files are copied back in or timestamps change.
    cache = params.cache_mode

    // Error handling
    errorStrategy = 'finish'

    withName: PREP_TARGET_VCF {
        conda = "${launchDir}/envs/prep_target_vcf.yml"
    }

    withName: PREP_REFERENCE {
        conda = "${launchDir}/envs/prep_reference.yml"
    }

    withName: PHASE_AUTOSOMES {
        conda = "${launchDir}/envs/phase_autosomes.yml"
    }

    withName: IMPUTE_AUTOSOMES {
        conda = "${launchDir}/envs/impute_autosomes.yml"
    }

    withName: IMPUTE_CHRX {
        conda = "${launchDir}/envs/impute_chrx.yml"
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = params.slurm_partition
        process.cpus = 4
        process.memory = '16GB'
        process.time = '10h'
        // On low_p, tasks can be interrupted by scheduler signals. Retry only
        // those interruption-style exits, while still terminating immediately
        // on real pipeline/data errors.
        process.errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'terminate' }
        process.maxRetries = 2
    }
}

timeline {
    enabled = true
    file    = "${params.outdir}/stage2-pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/stage2-pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/stage2-pipeline_info/execution_trace.txt"
    overwrite = true
}
